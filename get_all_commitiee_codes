import os
import yaml
import json

# 1. Configuration
folder_path = 'committee_history'
output_file = 'distinct_committees.json'
unique_committees = set()

print(f"Scanning folder: {folder_path}...")

# 2. Walk through the directory
try:
    for filename in os.listdir(folder_path):
        if filename.endswith(".yaml") or filename.endswith(".yml"):
            file_path = os.path.join(folder_path, filename)
            
            try:
                with open(file_path, 'r') as f:
                    # Load the YAML content
                    content = yaml.safe_load(f)
                    
                    # The content is a dictionary where keys are committee codes
                    # e.g. {'SSAF': [...], 'SSAP': [...]}
                    if content and isinstance(content, dict):
                        # Add all keys (committee codes) to our set
                        unique_committees.update(content.keys())
                        
            except Exception as e:
                print(f"Error reading {filename}: {e}")

    # 3. Save the results
    sorted_committees = sorted(list(unique_committees))
    
    print(f"\nFound {len(sorted_committees)} distinct committees.")
    
    # Save as a simple JSON list
    with open(output_file, 'w') as f:
        json.dump(sorted_committees, f, indent=4)
        
    print(f"Saved list to {output_file}")
    
    # Print preview
    print("\nPreview of found codes:")
    print(sorted_committees[:10])  # Print first 10

except FileNotFoundError:
    print(f"Error: The folder '{folder_path}' does not exist.")
